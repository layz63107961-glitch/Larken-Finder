    for i=1,5 do
        task.wait(0.04)
        KeyBox.Position=UDim2.new(orig.X.Scale,orig.X.Offset+(i%2==0 and 9 or -9),orig.Y.Scale,orig.Y.Offset)
    end
    task.wait(0.04); KeyBox.Position=orig
end

