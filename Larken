local function openHub()
    KeyFrame.Visible = false
    HubFrame.Visible = true
    HubFrame.Size = UDim2.new(0, 0, 0, 0)
    HubFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    TweenService:Create(HubFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 720, 0, 480),
        Position = UDim2.new(0.5, -360, 0.5, -240)
    }):Play()

    -- Charger brainrots initiaux
    task.delay(0.5, function()
        local shuffled = {}
        for _, b in ipairs(BRAINROTS) do table.insert(shuffled, b) end
        -- Shuffle
        for i = #shuffled, 2, -1 do
            local j = math.random(i)
            shuffled[i], shuffled[j] = shuffled[j], shuffled[i]
        end
        for k = 1, math.min(8, #shuffled) do
            task.delay((k-1)*0.08, function()
                createCard(shuffled[k], nil, nil, false)
            end)
        end
    end)

    -- Live feed toutes les 3-7 secondes
    task.spawn(function()
        while HubFrame.Visible do
            task.wait(randInt(30, 70) / 10)
            local br = randItem(BRAINROTS)
            createCard(br, nil, nil, true)
        end
    end)

    -- Clignotement status dot
    task.spawn(function()
        while true do
            task.wait(0.7)
            TweenService:Create(StatusDot, TweenInfo.new(0.4), {
                BackgroundTransparency = 0.8
            }):Play()
            task.wait(0.4)
            TweenService:Create(StatusDot, TweenInfo.new(0.4), {
                BackgroundTransparency = 0
            }):Play()
        end
    end)
end

KeyBtn.MouseButton1Click:Connect(function()
    local key = KeyInput.Text:upper():gsub("%s+","")
    if isValidKey(key) then
        KeyError.Visible = false
        openHub()
    else
        KeyError.Visible = true
        -- Shake animation
        local origPos = KeyBox.Position
        for i = 1, 4 do
            task.wait(0.04)
            KeyBox.Position = UDim2.new(origPos.X.Scale, origPos.X.Offset + (i%2==0 and 8 or -8), origPos.Y.Scale, origPos.Y.Offset)
        end
        task.wait(0.04)
        KeyBox.Position = origPos
    end
end)

