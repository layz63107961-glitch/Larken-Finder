local function checkKey(raw)
    local k = raw:upper():gsub("%s+","")
    if k == DEV_PASSWORD then
        local uname = LocalPlayer.Name
        for _, u in ipairs(DEV_USERNAMES) do
            if u:lower() == uname:lower() then return "dev" end
        end
        return "not_dev"
    end
    for _, v in ipairs(SUPREME_KEYS) do
        if v == k then
            if isKeyUsed(k) then return "used" end
            markKeyUsed(k); return "supreme"
        end
    end
    for _, v in ipairs(NORMAL_KEYS) do
        if v == k then
            if isKeyUsed(k) then return "used" end
            markKeyUsed(k); return "normal"
        end
    end
    return "invalid"
end

