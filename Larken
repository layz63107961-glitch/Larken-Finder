    local tierColor = tier == 3 and Color3.fromRGB(255,45,120)
                   or tier == 2 and Color3.fromRGB(255,107,0)
                   or Color3.fromRGB(100, 180, 255)

    local tierTag = tier == 3 and "TIER 3  •  100M+ MAX"
