end

local function doJoin(brainrot,server,speed,joinBtn,noJoinLbl)
    if joinBtn.Text=="JOINED" or joinBtn.Text=="BLACKLISTED"
    or joinBtn.Text=="NO JOIN" or not joinBtn.Active then return end

    -- Vérif No Join (>= 3 fois)
    if isNoJoin(brainrot.name) then
        joinBtn.Text="NO JOIN"
        joinBtn.BackgroundColor3=Color3.fromRGB(40,40,40)
        joinBtn.TextColor3=Color3.fromRGB(120,120,120)
        joinBtn.Active=false
        if noJoinLbl then
            noJoinLbl.Text=brainrot.name:upper().." — No Join (limite atteinte)"
            noJoinLbl.Visible=true
        end
        return
    end

    joinBtn.Text="JOINING..."; joinBtn.Active=false
    joinBtn.BackgroundColor3=Color3.fromRGB(26,26,45)

    task.delay(randInt(8,18)/10,function()
        -- Incrémenter le compteur
        incrementJoin(brainrot.name)
        local count = getJoinCount(brainrot.name)
        local remaining = MAX_JOINS - count

        -- Mettre à jour le bouton
        if count >= MAX_JOINS then
            joinBtn.Text="NO JOIN"
            joinBtn.BackgroundColor3=Color3.fromRGB(40,40,40)
            joinBtn.TextColor3=Color3.fromRGB(120,120,120)
            if noJoinLbl then
                noJoinLbl.Text=brainrot.name:upper().." — No Join ("..count.."/"..MAX_JOINS.." atteint)"
                noJoinLbl.Visible=true
            end
        else
            joinBtn.Text="JOINED ("..remaining.." left)"
            joinBtn.BackgroundColor3=Color3.fromRGB(57,255,20)
            joinBtn.TextColor3=Color3.fromRGB(0,0,0)
            joinBtn.Active=true -- peut rejoindre encore
        end

        showToast(brainrot,server,speed)

        -- Téléport vers serveur 90%+ full
        task.delay(0.6,function()
            local TS=game:GetService("TeleportService")
            local ok,_=pcall(function()
                local url="https://games.roblox.com/v1/games/"..PLACE_ID
                    .."/servers/Public?sortOrder=Desc&limit=100"
                local resp=game:HttpGet(url)
                local data=HttpService:JSONDecode(resp)

                if data and data.data and #data.data>0 then
                    -- Filtre 90%+ de remplissage
                    local fullServers={}
                    local halfServers={}
                    for _,s in ipairs(data.data) do
                        local ratio = s.maxPlayers>0 and (s.playing/s.maxPlayers) or 0
                        if ratio>=0.9 and s.playing<s.maxPlayers then
                            table.insert(fullServers,s)
                        elseif ratio>=0.5 and s.playing<s.maxPlayers then
                            table.insert(halfServers,s)
                        end
                    end

                    -- Priorité : 90%+ → 50%+ → n'importe lequel
                    local pool
                    if #fullServers>0 then
                        pool=fullServers
                    elseif #halfServers>0 then
                        pool=halfServers
                    else
                        pool=data.data
                    end

                    local picked=pool[math.random(#pool)]
                    -- TeleportOptions pour spawn à base aléatoire
                    local teleOpts=Instance.new("TeleportOptions")
                    teleOpts.ShouldReserveServer=false
                    TS:TeleportToPlaceInstance(PLACE_ID,picked.id,LocalPlayer,"",teleOpts)
                else
                    TS:Teleport(PLACE_ID,LocalPlayer)
                end
            end)
            if not ok then
                pcall(function() TS:Teleport(PLACE_ID,LocalPlayer) end)
            end

            -- Équipe le tapis après le tp
            equipFirstTool()
            -- Spawn base aléatoire
            teleportToRandomBase()
        end)
    end)
end

local function createCard(brainrot,speed,server,isNew)
    local blocked=isBlacklisted(brainrot.name)
    if activeFilter~=0 and brainrot.tier~=activeFilter then return end
    if brainrot.tier==3 and accessLevel=="normal" then return end

    notifCount=notifCount+1; cardOrder=cardOrder+1
    CountTxt.Text=notifCount.." NOTIFICATIONS"

    local spd=speed or randInt(15,380)
    local srv=server or randItem(SERVERS)
    local tc=brainrot.tier==3 and Color3.fromRGB(255,45,120)
           or brainrot.tier==2 and Color3.fromRGB(255,107,0)
           or Color3.fromRGB(100,180,255)
    local tt=brainrot.tier==3 and "TIER 3  •  100M+ MAX"
           or brainrot.tier==2 and "TIER 2  •  25M-100M"
           or "TIER 1  •  1M-25M"
    local bc=brainrot.tier==2 and Color3.fromRGB(205,92,0) or Color3.fromRGB(185,0,72)

    -- Hauteur étendue pour le label No Join
    local card=Instance.new("Frame",ScrollFrame)
    card.Name="Card_"..cardOrder
    card.Size=UDim2.new(1,-8,0,84)
    card.BackgroundColor3=blocked and Color3.fromRGB(20,8,8) or Color3.fromRGB(16,16,26)
    card.BorderSizePixel=0; card.LayoutOrder=-cardOrder; card.ZIndex=7
    mkCorner(card,9)

    local ab=Instance.new("Frame",card)
    ab.Size=UDim2.new(0,3,1,-14); ab.Position=UDim2.new(0,0,0,7)
    ab.BackgroundColor3=blocked and Color3.fromRGB(110,28,28) or tc
    ab.BorderSizePixel=0; ab.ZIndex=8; mkCorner(ab,2)

    mkLabel(card,tt,8,Color3.fromRGB(65,65,88),Enum.Font.GothamBold,
        Enum.TextXAlignment.Left,UDim2.new(0,12,0,7),UDim2.new(0,220,0,14),8)
    mkLabel(card,(blocked and "🚫 " or "")..brainrot.name,14,
        blocked and Color3.fromRGB(155,55,55) or Color3.fromRGB(222,222,255),
        Enum.Font.GothamBold,Enum.TextXAlignment.Left,
        UDim2.new(0,12,0,22),UDim2.new(0,290,0,20),8)
    mkLabel(card,"SECRET: "..brainrot.secret,9,
        blocked and Color3.fromRGB(95,35,35) or tc,
        Enum.Font.GothamBold,Enum.TextXAlignment.Left,
        UDim2.new(0,12,0,43),UDim2.new(0,310,0,14),8)
    mkLabel(card,spd.."M/s  •  "..srv,9,Color3.fromRGB(50,50,70),
        Enum.Font.Gotham,Enum.TextXAlignment.Left,
        UDim2.new(0,12,0,58),UDim2.new(0,290,0,14),8)

    -- Label No Join (caché par défaut, s'affiche si limite atteinte)
    local noJoinLbl=Instance.new("TextLabel",card)
    noJoinLbl.Size=UDim2.new(1,-100,0,14)
    noJoinLbl.Position=UDim2.new(0,12,1,-18)
    noJoinLbl.BackgroundTransparency=1
    noJoinLbl.Text=""
    noJoinLbl.Font=Enum.Font.GothamBold
    noJoinLbl.TextSize=9
    noJoinLbl.TextColor3=Color3.fromRGB(180,60,60)
    noJoinLbl.TextXAlignment=Enum.TextXAlignment.Left
    noJoinLbl.ZIndex=9
    noJoinLbl.Visible=false

    -- Compteur visuel (ex: "2/3")
    local cntLbl=Instance.new("TextLabel",card)
    cntLbl.Size=UDim2.new(0,30,0,12)
    cntLbl.Position=UDim2.new(1,-118,0,8)
    cntLbl.BackgroundTransparency=1
    local jc=getJoinCount(brainrot.name)
    cntLbl.Text=jc.."/"..MAX_JOINS
    cntLbl.Font=Enum.Font.GothamBold
    cntLbl.TextSize=9
    cntLbl.TextColor3=jc>=MAX_JOINS and Color3.fromRGB(180,60,60) or Color3.fromRGB(70,70,100)
    cntLbl.TextXAlignment=Enum.TextXAlignment.Center
    cntLbl.ZIndex=9

    local joinBtn=Instance.new("TextButton",card)
    joinBtn.Size=UDim2.new(0,78,0,30); joinBtn.Position=UDim2.new(1,-90,0.5,-15)
    joinBtn.BorderSizePixel=0; joinBtn.Font=Enum.Font.GothamBold
    joinBtn.TextSize=9; joinBtn.ZIndex=9
    mkCorner(joinBtn,7)

    if blocked then
        joinBtn.Text="BLACKLISTED"
        joinBtn.BackgroundColor3=Color3.fromRGB(55,18,18)
        joinBtn.TextColor3=Color3.fromRGB(150,55,55)
        joinBtn.Active=false
    elseif isNoJoin(brainrot.name) then
        joinBtn.Text="NO JOIN"
        joinBtn.BackgroundColor3=Color3.fromRGB(38,38,38)
        joinBtn.TextColor3=Color3.fromRGB(110,110,110)
        joinBtn.Active=false
        noJoinLbl.Text=brainrot.name:upper().." — No Join (limite atteinte)"
        noJoinLbl.Visible=true
    else
        joinBtn.Text="JOIN"
        joinBtn.BackgroundColor3=bc
        joinBtn.TextColor3=Color3.fromRGB(255,255,255)
        joinBtn.Active=true
        joinBtn.MouseButton1Click:Connect(function()
            doJoin(brainrot,srv,spd,joinBtn,noJoinLbl)
            -- Met à jour le compteur visuel
            task.delay(0.1,function()
                local jc2=getJoinCount(brainrot.name)
                cntLbl.Text=jc2.."/"..MAX_JOINS
                cntLbl.TextColor3=jc2>=MAX_JOINS
                    and Color3.fromRGB(180,60,60) or Color3.fromRGB(70,70,100)
            end)
        end)
    end

    card.BackgroundTransparency=1
    TweenService:Create(card,TweenInfo.new(0.22,Enum.EasingStyle.Quart),
        {BackgroundTransparency=0}):Play()
    ScrollFrame.CanvasPosition=Vector2.new(0,0)

    if autoJoin and isNew and not blocked and not isNoJoin(brainrot.name) then
        task.delay(0.35,function() doJoin(brainrot,srv,spd,joinBtn,noJoinLbl) end)
    end
end

local function pickRandom() return RARITY_POOL[math.random(#RARITY_POOL)] end

local function loadInitial()
    local seen,count={},0
    local attempts=0
    while count<10 and attempts<100 do
        attempts=attempts+1
        local b=pickRandom()
        if not seen[b.name] then
            if not (b.tier==3 and accessLevel=="normal") then
                seen[b.name]=true; count=count+1
                local c=count
                task.delay((c-1)*0.07,function() createCard(b,nil,nil,false) end)
            end
        end
    end
end

local function openHub(level)
    accessLevel=level
    KeyFrame.Visible=false; HubFrame.Visible=true

    if level=="dev" then
        AccessBadge.Text="✦ DEVELOPPEUR"
        AccessBadge.TextColor3=Color3.fromRGB(57,255,20)
        AccessBadge.BackgroundColor3=Color3.fromRGB(8,32,8)
        HubStroke.Color=Color3.fromRGB(57,255,20)
    elseif level=="supreme" then
        AccessBadge.Text="★ SUPREME"
        AccessBadge.TextColor3=Color3.fromRGB(255,215,0)
        AccessBadge.BackgroundColor3=Color3.fromRGB(32,26,0)
        HubStroke.Color=Color3.fromRGB(255,215,0)
        HubStroke.Transparency=0
    else
        AccessBadge.Text="NORMAL"
        AccessBadge.TextColor3=Color3.fromRGB(130,130,170)
    end

    HubFrame.Size=UDim2.new(0,0,0,0)
    HubFrame.Position=UDim2.new(0.5,0,0.5,0)
    TweenService:Create(HubFrame,TweenInfo.new(0.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{
        Size=UDim2.new(0,790,0,530),
        Position=UDim2.new(0.5,-395,0.5,-265)
    }):Play()

    task.delay(0.45,loadInitial)

    -- Live feed
    task.spawn(function()
        while HubFrame.Visible do
            task.wait(randInt(28,65)/10)
            if not minimized then createCard(pickRandom(),nil,nil,true) end
        end
    end)

    -- Dot blink
    task.spawn(function()
        while HubFrame.Visible do
            task.wait(0.7)
            TweenService:Create(SbDot,TweenInfo.new(0.4),{BackgroundTransparency=0.8}):Play()
            task.wait(0.4)
            TweenService:Create(SbDot,TweenInfo.new(0.4),{BackgroundTransparency=0}):Play()
        end
    end)
end

